# ------------------------------------------
# Required: API Keys
# ------------------------------------------

# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# DeepSeek — use as the default chat model when OPENAI_API_KEY is unset, or set USE_DEEPSEEK=1
# to prefer DeepSeek when both keys are present. Get key: https://platform.deepseek.com/
# DEEPSEEK_API_KEY=
# USE_DEEPSEEK=1
# DEEPSEEK_MODEL_ID=deepseek-chat
#
# Embeddings for Knowledge/RAG (Dash, Investment, my_kb load_knowledge, etc.)
# - openai (default when OPENAI_API_KEY is set): OpenAIEmbedder.
# - deepseek: official api has no working /v1/embeddings; repo uses DeepSeek *chat* model
#   (DEEPSEEK_EMBEDDING_MODEL / DEEPSEEK_MODEL_ID) to emit a JSON vector — slower, costs tokens.
#   Set USE_DEEPSEEK=1 + DEEPSEEK_API_KEY and leave OPENAI_API_KEY empty to auto-pick deepseek.
# EMBEDDING_PROVIDER=openai
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_PROVIDER=deepseek
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_EMBEDDING_MODEL=deepseek-v4-flash
# DEEPSEEK_EMBEDDING_DIMENSIONS=256

# ------------------------------------------
# Optional: API Keys
# ------------------------------------------

# Web search for Reasoner, Reporter, Contacts, AI Research, Investment Market Analyst
# EXA_API_KEY=

# Enhanced research for Investment Market Analyst
# PARALLEL_API_KEY=

# Anthropic — Reasoner fallback + registry models (Claude Sonnet, Haiku)
# ANTHROPIC_API_KEY=

# Google — registry models (Gemini 3 Flash, Gemini 2.5 Pro)
# GOOGLE_API_KEY=

# TTS for Studio, Repo Walkthrough
# ELEVEN_LABS_API_KEY=

# Image-to-image for Studio
# FAL_KEY=

# Video generation for Studio (LumaLab)
# LUMAAI_API_KEY=

# ------------------------------------------
# Optional: Slack
# ------------------------------------------

# Create app from the manifest in docs/SLACK_CONNECT.md.
# Bot token (xoxb-...) from the Install App page.
# Signing secret from Basic Information -> App Credentials.
# SLACK_TOKEN=
# SLACK_SIGNING_SECRET=

# ------------------------------------------
# Database
# ------------------------------------------

# Defaults work out of the box with Docker Compose.
# Only change these if you're using an external database.
# DB_USER=ai
# DB_PASS=ai
# DB_HOST=localhost
# DB_PORT=5432
# DB_DATABASE=ai

# ------------------------------------------
# Local vs production runtime
# ------------------------------------------

# Local / IDE: omit or use dev (default in app/settings.py) — no JWT middleware.
# RUNTIME_ENV=dev

# ------------------------------------------
# Production: Security
# ------------------------------------------

# RBAC is enabled automatically when RUNTIME_ENV=prd.
# Generate a key pair at os.agno.com -> Settings.
# Paste the public key below (including BEGIN/END lines).
# See: https://docs.agno.com/agent-os/security/overview
# See: https://docs.agno.com/agent-os/security/rbac
# JWT_VERIFICATION_KEY=

# ------------------------------------------
# Production: Server
# ------------------------------------------

# Scheduler callback URL for production deployments.
# In dev mode, defaults to http://127.0.0.1:8000.
# AGENTOS_URL=https://demo.example.com

# ------------------------------------------
# Production: Deployment
# ------------------------------------------

# Local dev uses .env (Docker Compose default).
# Production uses .env.production (Railway via railway_env.sh).
#
# Setup:
#   Local:       cp example.env .env
#   Production:  cp example.env .env.production
#
# Deploy to Railway:
#   First time:  ./scripts/railway_up.sh
#   Redeploy:    ./scripts/railway_redeploy.sh
#   Sync env:    ./scripts/railway_env.sh (reads .env.production)
#
# Secure your deployment:
#   1. Set RUNTIME_ENV=prd
#   2. Set JWT_VERIFICATION_KEY from os.agno.com
#   3. Connect at os.agno.com -> Add OS -> your deployed URL
